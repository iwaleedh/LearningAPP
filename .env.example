# SpacetimeDB connection settings
# For local development (default):
VITE_SPACETIMEDB_URI=http://localhost:3000
VITE_SPACETIMEDB_MODULE=spacetime-backend-otpgp

# For production (mainnet SpacetimeDB):
# VITE_SPACETIMEDB_URI=https://mainnet.spacetimedb.com
# VITE_SPACETIMEDB_MODULE=your-production-module-name

# Firebase Realtime Database (for cross-device Live Class sync)
# Create a free Firebase project at https://console.firebase.google.com
# 1. Create project → 2. Build → Realtime Database → Create Database
# 3. Set rules to allow read/write (see README) → 4. Copy config below
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_AUTH_DOMAIN=
