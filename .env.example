# Convex connection settings
# Get this URL from `npx convex dev` or the Convex dashboard
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Clerk settings
# Set these only if you want authenticated Convex requests with Clerk.
# If you use teacher roles, include a role claim in the Clerk Convex JWT template
# or session token, for example `role` or `public_metadata.role`.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_example
CLERK_FRONTEND_API_URL=https://your-instance.clerk.accounts.dev

# Server-side webhook secret for Convex /api/webhook requests.
# Set this in your Convex deployment environment variables, not as a public Vite client variable.
WEBHOOK_SHARED_SECRET=replace-with-a-long-random-secret
