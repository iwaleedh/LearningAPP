    "deploy": "gh-pages -d dist",
    "convex:deploy": "npx convex deploy"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.61.4",
    "chart.js": "^4.5.1",
    "convex": "^1.32.0",
