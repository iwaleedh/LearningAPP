  "version": "0.0.0",
  "type": "module",
  "homepage": "https://iwaleedh.github.io/LearningAPP",
  "scripts": {
    "dev": "npm run pastpapers:manifest && vite",
    "build": "npm run pastpapers:manifest && vite build",
